# API base URL. Must be configured in production/staging (services/api.ts throws
# without it); defaults are dev-only.
VITE_API_URL=http://localhost:8000/v1

# PostHog analytics + client-side error tracking (spec-081). Unset VITE_POSTHOG_KEY
# ⇒ init() is a no-op (dev/test/e2e default) — no events are ever sent. Privacy is
# binding: autocapture off, session recording off, identified_only profiles, no
# financial values/captured text/entity names in event properties (see
# src/lib/analytics.ts).
# VITE_POSTHOG_KEY=your-posthog-project-api-key
# VITE_POSTHOG_HOST=https://us.i.posthog.com
